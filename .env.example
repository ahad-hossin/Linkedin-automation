# Copy this file to .env and fill in your own keys (never commit .env).
# This project uses its OWN keys — do not reuse the news bot's.

# --- LLM (at least one provider required for `generate`) ---
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GROQ_API_KEY=

# --- LinkedIn (only needed for `publish`; dry-runs without them) ---
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
